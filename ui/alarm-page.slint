// ============================================================
//  alarm-page.slint - 闹钟页面：列表 + 编辑弹窗
// ============================================================

import { AmberTheme, GlassButton, GlassInput, AlarmCard } from "widgets.slint";

// -------- 闹钟编辑弹窗 --------
export component AlarmEditor inherits Rectangle {
    in-out property <string> alarm-id;
    in-out property <string> hour-text;
    in-out property <string> minute-text;
    in-out property <string> memo-text;
    callback save-clicked(string, string, string, string);
    callback cancel-clicked();

    background: rgba(180, 200, 220, 0.25);

    // 居中卡片
    card := Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: min(parent.width - 40px, 340px);
        height: layout.preferred-height + 40px;
        border-radius: AmberTheme.radius-lg;
        background: rgba(255, 255, 255, 0.92);
        border-width: 1px;
        border-color: AmberTheme.border-glass;

        layout := VerticalLayout {
            x: 20px;
            y: 20px;
            width: parent.width - 40px;
            spacing: 14px;

            Text {
                text: root.alarm-id == "" ? "新建闹钟" : "编辑闹钟";
                color: AmberTheme.accent;
                font-size: 16px;
                font-weight: 700;
            }

            // 时间输入行
            HorizontalLayout {
                spacing: 8px;
                alignment: center;

                hour-input := GlassInput {
                    text <=> root.hour-text;
                    placeholder: "时";
                    width: 80px;
                }

                Text {
                    text: ":";
                    color: AmberTheme.accent;
                    font-size: 28px;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                minute-input := GlassInput {
                    text <=> root.minute-text;
                    placeholder: "分";
                    width: 80px;
                }
            }

            // 备忘录
            memo-input := GlassInput {
                text <=> root.memo-text;
                placeholder: "备忘录（可选）";
                multi-line: true;
                height: 80px;
            }

            // 按钮行
            HorizontalLayout {
                spacing: 10px;
                alignment: end;

                GlassButton {
                    label: "取消";
                    clicked => { root.cancel-clicked(); }
                }

                GlassButton {
                    label: "✓ 保存";
                    active: true;
                    clicked => {
                        root.save-clicked(root.alarm-id, root.hour-text, root.minute-text, root.memo-text);
                    }
                }
            }
        }
    }
}

// -------- 闹钟页面 --------
export component AlarmPage inherits Rectangle {
    in-out property <[string]> alarm-ids;
    in-out property <[string]> alarm-times;
    in-out property <[string]> alarm-memos;
    in-out property <[bool]> alarm-enables;

    // 编辑器状态
    in-out property <bool> editor-visible: false;
    in-out property <string> edit-id: "";
    in-out property <string> edit-hour: "";
    in-out property <string> edit-minute: "";
    in-out property <string> edit-memo: "";

    callback save-alarm(string, string, string, string);
    callback delete-alarm(string);
    callback toggle-alarm(string);

    background: transparent;

    VerticalLayout {
        spacing: 12px;
        padding: 16px;

        // 添加按钮行
        HorizontalLayout {
            alignment: end;

            GlassButton {
                label: "+ 新建闹钟";
                active: true;
                clicked => {
                    root.editor-visible = true;
                    root.edit-id = "";
                    root.edit-hour = "";
                    root.edit-minute = "";
                    root.edit-memo = "";
                }
            }
        }

        // 闹钟列表
        Flickable {
            vertical-stretch: 1;
            viewport-height: alarms-list.preferred-height;

            alarms-list := VerticalLayout {
                spacing: 10px;

                for id[i] in root.alarm-ids: AlarmCard {
                    alarm-id: id;
                    time: root.alarm-times[i];
                    memo: root.alarm-memos[i];
                    enabled: root.alarm-enables[i];
                    toggle-clicked(id) => { root.toggle-alarm(id); }
                    delete-clicked(id) => { root.delete-alarm(id); }
                }

                // 空状态
                if root.alarm-ids.length == 0: Rectangle {
                    height: 120px;
                    border-radius: AmberTheme.radius-md;
                    background: rgba(255, 255, 255, 0.25);
                    border-width: 1px;
                    border-color: AmberTheme.border-glass;

                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;

                        Text {
                            text: "⏰";
                            font-size: 28px;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "暂无闹钟，点击上方按钮新建";
                            color: AmberTheme.text-secondary;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // 编辑弹窗（覆盖层）
    if root.editor-visible: AlarmEditor {
        width: root.width;
        height: root.height;
        alarm-id <=> root.edit-id;
        hour-text <=> root.edit-hour;
        minute-text <=> root.edit-minute;
        memo-text <=> root.edit-memo;
        save-clicked(id, hour, minute, memo) => {
            root.save-alarm(id, hour, minute, memo);
            root.editor-visible = false;
        }
        cancel-clicked() => { root.editor-visible = false; }
    }
}
