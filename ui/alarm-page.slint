// ============================================================
//  alarm-page.slint - 闹钟页面：列表 + 编辑弹窗
// ============================================================

import { AmberTheme, GlassButton, GlassInput, AlarmCard } from "widgets.slint";

component StepperInput inherits Rectangle {
    in-out property <string> value;
    in property <string> label;
    callback increase();
    callback decrease();

    height: 96px;
    border-radius: AmberTheme.radius-md;
    background: rgba(255, 255, 255, 0.80);
    border-width: 1px;
    border-color: AmberTheme.border-glass;

    VerticalLayout {
        x: 6px;
        y: 6px;
        width: parent.width - 12px;
        height: parent.height - 12px;
        spacing: 4px;
        alignment: center;

        Text {
            text: root.label;
            color: AmberTheme.text-secondary;
            font-size: 11px;
            horizontal-alignment: center;
        }

        GlassButton {
            label: "+";
            icon-only: true;
            width: 28px;
            height: 20px;
            clicked => { root.increase(); }
        }

        GlassInput {
            width: parent.width;
            height: 30px;
            text <=> root.value;
            placeholder: "";
        }

        GlassButton {
            label: "-";
            icon-only: true;
            width: 28px;
            height: 20px;
            clicked => { root.decrease(); }
        }
    }
}

export component AlarmEditor inherits Rectangle {
    in-out property <string> alarm-id;
    in-out property <string> year-value: "2026";
    in-out property <string> month-value: "1";
    in-out property <string> day-value: "1";
    in-out property <string> hour-value: "0";
    in-out property <string> minute-value: "0";
    in-out property <string> memo-text;
    callback save-clicked(string, string, string, string, string, string, string);
    callback cancel-clicked();
    callback adjust-field(string, int);

    background: rgba(180, 200, 220, 0.25);

    card := Rectangle {
        x: (parent.width - self.width) / 2;
        y: max(12px, (parent.height - self.height) / 2);
        width: min(parent.width - 24px, 396px);
        height: min(parent.height - 24px, content-layout.preferred-height + 28px);
        border-radius: AmberTheme.radius-lg;
        background: rgba(255, 255, 255, 0.94);
        border-width: 1px;
        border-color: AmberTheme.border-glass;

        scroller := Flickable {
            x: 14px;
            y: 14px;
            width: parent.width - 28px;
            height: parent.height - 28px;
            viewport-height: content-layout.preferred-height;

            content-layout := VerticalLayout {
                width: parent.width;
                spacing: 12px;

                Text {
                    text: root.alarm-id == "" ? "新建闹钟" : "编辑闹钟";
                    color: AmberTheme.accent;
                    font-size: 16px;
                    font-weight: 700;
                }

                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;

                    StepperInput {
                        width: 76px;
                        label: "年";
                        value <=> root.year-value;
                        increase() => { root.adjust-field("year", 1); }
                        decrease() => { root.adjust-field("year", -1); }
                    }

                    StepperInput {
                        width: 58px;
                        label: "月";
                        value <=> root.month-value;
                        increase() => { root.adjust-field("month", 1); }
                        decrease() => { root.adjust-field("month", -1); }
                    }

                    StepperInput {
                        width: 58px;
                        label: "日";
                        value <=> root.day-value;
                        increase() => { root.adjust-field("day", 1); }
                        decrease() => { root.adjust-field("day", -1); }
                    }

                    StepperInput {
                        width: 58px;
                        label: "时";
                        value <=> root.hour-value;
                        increase() => { root.adjust-field("hour", 1); }
                        decrease() => { root.adjust-field("hour", -1); }
                    }

                    StepperInput {
                        width: 58px;
                        label: "分";
                        value <=> root.minute-value;
                        increase() => { root.adjust-field("minute", 1); }
                        decrease() => { root.adjust-field("minute", -1); }
                    }
                }

                memo-input := GlassInput {
                    text <=> root.memo-text;
                    placeholder: "备注（可选）";
                    multi-line: true;
                    height: 64px;
                }

                HorizontalLayout {
                    spacing: 10px;
                    alignment: end;

                    GlassButton {
                        label: "取消";
                        clicked => { root.cancel-clicked(); }
                    }

                    GlassButton {
                        label: "保存";
                        active: true;
                        clicked => {
                            root.save-clicked(
                                root.alarm-id,
                                root.year-value,
                                root.month-value,
                                root.day-value,
                                root.hour-value,
                                root.minute-value,
                                root.memo-text
                            );
                        }
                    }
                }
            }
        }
    }
}

export component AlarmPage inherits Rectangle {
    in-out property <[string]> alarm-ids;
    in-out property <[string]> alarm-times;
    in-out property <[string]> alarm-memos;
    in-out property <[bool]> alarm-enables;

    in-out property <bool> editor-visible: false;
    in-out property <string> edit-id: "";
    in-out property <string> edit-year: "2026";
    in-out property <string> edit-month: "1";
    in-out property <string> edit-day: "1";
    in-out property <string> edit-hour: "0";
    in-out property <string> edit-minute: "0";
    in-out property <string> edit-memo: "";

    callback save-alarm(string, string, string, string, string, string, string);
    callback delete-alarm(string);
    callback toggle-alarm(string);
    callback prepare-new-alarm();
    callback adjust-alarm-field(string, int);

    background: transparent;

    VerticalLayout {
        spacing: 12px;
        padding: 16px;

        HorizontalLayout {
            alignment: end;

            GlassButton {
                label: "+ 新建闹钟";
                active: true;
                clicked => { root.prepare-new-alarm(); }
            }
        }

        Flickable {
            vertical-stretch: 1;
            viewport-height: alarms-list.preferred-height;

            alarms-list := VerticalLayout {
                spacing: 10px;

                for id[i] in root.alarm-ids: AlarmCard {
                    alarm-id: id;
                    time: root.alarm-times[i];
                    memo: root.alarm-memos[i];
                    enabled: root.alarm-enables[i];
                    toggle-clicked(id) => { root.toggle-alarm(id); }
                    delete-clicked(id) => { root.delete-alarm(id); }
                }

                if root.alarm-ids.length == 0: Rectangle {
                    height: 120px;
                    border-radius: AmberTheme.radius-md;
                    background: rgba(255, 255, 255, 0.25);
                    border-width: 1px;
                    border-color: AmberTheme.border-glass;

                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;

                        Text {
                            text: "铃";
                            font-size: 28px;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "暂无闹钟，点击上方按钮新建";
                            color: AmberTheme.text-secondary;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }
    }

    if root.editor-visible: AlarmEditor {
        width: root.width;
        height: root.height;
        alarm-id <=> root.edit-id;
        year-value <=> root.edit-year;
        month-value <=> root.edit-month;
        day-value <=> root.edit-day;
        hour-value <=> root.edit-hour;
        minute-value <=> root.edit-minute;
        memo-text <=> root.edit-memo;
        adjust-field(field, delta) => { root.adjust-alarm-field(field, delta); }
        save-clicked(id, year, month, day, hour, minute, memo) => {
            root.save-alarm(id, year, month, day, hour, minute, memo);
            root.editor-visible = false;
        }
        cancel-clicked() => { root.editor-visible = false; }
    }
}
